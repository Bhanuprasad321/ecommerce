### 1. Create Order (make sure cart has items first)
POST http://localhost:8000/api/orders
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YTZhMjc2ZTNmYWNkYTA1NjMxZmJmMSIsImlhdCI6MTc3NTE5NTY4NywiZXhwIjoxNzc1ODAwNDg3fQ.tmyZZDUemNt1F_xFlxlf4pRCdP05gE1JsN9EQb9LfRA

{
  "shippingAddress": {
    "street": "123 Main St",
    "city": "Hyderabad",
    "state": "Telangana",
    "zip": "500001"
  }
}

